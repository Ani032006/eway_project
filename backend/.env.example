PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/eway_intelligence

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173

ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin123
SYNC_ADMIN_PASSWORD=true

# ── Email Configuration ───────────────────────────────────────────────────────
#
# OPTION A — Resend (RECOMMENDED — works on ANY network, uses HTTPS port 443)
#   1. Sign up FREE at: https://resend.com
#   2. Go to API Keys → Create API Key
#   3. Paste the key below (starts with "re_")
#
# RESEND_API_KEY=re_your_resend_api_key_here
#
# OPTION B — Gmail SMTP (may be blocked by ISP/college/office networks)
#   Requires: App Password (16 chars) from myaccount.google.com/security
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=E-Way Intelligence <your_email@gmail.com>
